<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
	xmlns:android="http://schemas.android.com/apk/res/android"
	android:layout_width="match_parent"
	android:layout_height="wrap_content"
	android:orientation="vertical"
	android:padding="24dp">

	<com.google.android.material.textfield.TextInputLayout
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:hint="Clone label suffix">

		<com.google.android.material.textfield.TextInputEditText
			android:id="@+id/labelEditText"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:text="Clone"
			android:inputType="text"
			android:maxLines="1" />

	</com.google.android.material.textfield.TextInputLayout>

	<com.google.android.material.checkbox.MaterialCheckBox
		android:id="@+id/deepCloneCheckbox"
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:layout_marginTop="16dp"
		android:text="Deep clone (patch DEX strings)"
		android:checked="false" />

	<TextView
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:layout_marginTop="4dp"
		android:layout_marginStart="32dp"
		android:text="Fixes apps that hardcode their own package name in code. Slower but more compatible."
		android:textSize="12sp"
		android:textColor="?android:textColorSecondary" />

	<com.google.android.material.checkbox.MaterialCheckBox
		android:id="@+id/patchNativeCheckbox"
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:layout_marginTop="12dp"
		android:text="Patch native libraries (risky)"
		android:checked="false" />

	<TextView
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:layout_marginTop="4dp"
		android:layout_marginStart="32dp"
		android:text="Replaces package name in .so files. May corrupt binaries — only use if clone crashes without it."
		android:textSize="12sp"
		android:textColor="?android:textColorSecondary" />

</LinearLayout>
