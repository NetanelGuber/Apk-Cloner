<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Clone name -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Clone name">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/labelEditText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text"
                android:maxLines="1"
                android:scrollHorizontally="true" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- ── Icon section header ─────────────────────────────────────── -->
        <LinearLayout
            android:id="@+id/iconHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="16dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:clickable="true"
            android:focusable="true"
            android:background="?android:attr/selectableItemBackground">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Icon"
                android:textStyle="bold"
                android:textSize="14sp"
                android:textColor="?android:textColorPrimary" />

            <TextView
                android:id="@+id/iconChevron"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="&#9658;"
                android:textSize="14sp"
                android:textColor="?android:textColorSecondary" />

        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="?android:attr/listDivider" />

        <!-- Icon content -->
        <LinearLayout
            android:id="@+id/iconContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:paddingTop="12dp"
            android:paddingBottom="8dp">

            <!-- Live icon preview -->
            <ImageView
                android:id="@+id/iconPreview"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="16dp"
                android:scaleType="fitCenter"
                android:contentDescription="Icon preview" />

            <!-- Hue -->
            <TextView
                android:id="@+id/hueLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Hue: 0°"
                android:textSize="12sp"
                android:textColor="?android:textColorSecondary" />

            <com.google.android.material.slider.Slider
                android:id="@+id/hueSlider"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:valueFrom="-180"
                android:valueTo="180"
                android:stepSize="1"
                android:value="0" />

            <!-- Saturation -->
            <TextView
                android:id="@+id/saturationLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Saturation: 0"
                android:textSize="12sp"
                android:textColor="?android:textColorSecondary" />

            <com.google.android.material.slider.Slider
                android:id="@+id/saturationSlider"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:valueFrom="-100"
                android:valueTo="100"
                android:stepSize="1"
                android:value="0" />

            <!-- Contrast -->
            <TextView
                android:id="@+id/contrastLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Contrast: 0"
                android:textSize="12sp"
                android:textColor="?android:textColorSecondary" />

            <com.google.android.material.slider.Slider
                android:id="@+id/contrastSlider"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:valueFrom="-100"
                android:valueTo="100"
                android:stepSize="1"
                android:value="0" />

        </LinearLayout>

        <!-- After cloning action -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="After cloning:"
            android:textStyle="bold"
            android:textSize="14sp"
            android:textColor="?android:textColorPrimary" />

        <RadioGroup
            android:id="@+id/actionRadioGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <com.google.android.material.radiobutton.MaterialRadioButton
                android:id="@+id/radioInstall"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Install"
                android:checked="true" />

            <com.google.android.material.radiobutton.MaterialRadioButton
                android:id="@+id/radioSave"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Save to storage" />

            <com.google.android.material.radiobutton.MaterialRadioButton
                android:id="@+id/radioInstallAndSave"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Install + Save to storage" />

        </RadioGroup>

        <!-- Save location row — visible only when a save option is selected -->
        <LinearLayout
            android:id="@+id/saveLocationSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="2dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/saveLocationText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Save to: Downloads/APK Cloner (default)"
                android:textSize="12sp"
                android:textColor="?android:textColorSecondary"
                android:paddingStart="8dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/browseButton"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Browse…"
                android:textSize="12sp"
                android:minHeight="0dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp" />

        </LinearLayout>

        <!-- Compatibility section header -->
        <LinearLayout
            android:id="@+id/compatibilityHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="16dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:clickable="true"
            android:focusable="true"
            android:background="?android:attr/selectableItemBackground">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Compatibility"
                android:textStyle="bold"
                android:textSize="14sp"
                android:textColor="?android:textColorPrimary" />

            <TextView
                android:id="@+id/compatibilityChevron"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="&#9658;"
                android:textSize="14sp"
                android:textColor="?android:textColorSecondary" />

        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="?android:attr/listDivider" />

        <!-- Compatibility content -->
        <LinearLayout
            android:id="@+id/compatibilityContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <com.google.android.material.checkbox.MaterialCheckBox
                android:id="@+id/deepCloneCheckbox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Deep clone (patch DEX strings)"
                android:checked="false" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:layout_marginStart="32dp"
                android:text="Fixes apps that hardcode their own package name in code. Slower but more compatible."
                android:textSize="12sp"
                android:textColor="?android:textColorSecondary" />

            <com.google.android.material.checkbox.MaterialCheckBox
                android:id="@+id/patchNativeCheckbox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Patch native libraries (risky)"
                android:checked="false" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:layout_marginStart="32dp"
                android:text="Replaces package name in .so files. May corrupt binaries — only use if clone crashes without it."
                android:textSize="12sp"
                android:textColor="?android:textColorSecondary" />

            <com.google.android.material.checkbox.MaterialCheckBox
                android:id="@+id/dualDexCheckbox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Dual DEX (bundle original + shim)"
                android:checked="false" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:layout_marginStart="32dp"
                android:text="Bundles the original code alongside a thin compatibility shim. Significantly increases app size. Use as an alternative to Deep clone if that option causes crashes."
                android:textSize="12sp"
                android:textColor="?android:textColorSecondary" />

            <com.google.android.material.checkbox.MaterialCheckBox
                android:id="@+id/pkgShimCheckbox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Package name shim"
                android:checked="false" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:layout_marginStart="32dp"
                android:text="Overrides getPackageName() to return the original package name. Use for games that lose save data after cloning. Warning: may crash apps that use the package name for system lookups (e.g. AndroidX Startup)."
                android:textSize="12sp"
                android:textColor="?android:textColorSecondary" />

            <com.google.android.material.checkbox.MaterialCheckBox
                android:id="@+id/spoofSignaturesCheckbox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Spoof signatures"
                android:checked="false" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="8dp"
                android:layout_marginStart="32dp"
                android:text="Makes the clone report the original app's signing certificate when queried via PackageManager. Use for apps/games that detect re-signing and refuse to run. Requires Android 5.0+."
                android:textSize="12sp"
                android:textColor="?android:textColorSecondary" />

        </LinearLayout>

        <!-- Manifest section header -->
        <LinearLayout
            android:id="@+id/manifestHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="12dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:clickable="true"
            android:focusable="true"
            android:background="?android:attr/selectableItemBackground">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Manifest"
                android:textStyle="bold"
                android:textSize="14sp"
                android:textColor="?android:textColorPrimary" />

            <TextView
                android:id="@+id/manifestChevron"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="&#9658;"
                android:textSize="14sp"
                android:textColor="?android:textColorSecondary" />

        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="?android:attr/listDivider" />

        <!-- Manifest content -->
        <LinearLayout
            android:id="@+id/manifestContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <!-- Custom package name -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/customPackageLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="Custom package name"
                app:helperText="Leave blank for auto-generated"
                app:helperTextEnabled="true">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/customPackageEditText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textNoSuggestions"
                    android:maxLines="1"
                    android:scrollHorizontally="true" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Min SDK override -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/minSdkLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="Override min SDK"
                app:helperTextEnabled="true">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/minSdkEditText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="number"
                    android:maxLines="1" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Target SDK override -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/targetSdkLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="8dp"
                android:hint="Override target SDK"
                app:helperTextEnabled="true">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/targetSdkEditText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="number"
                    android:maxLines="1" />

            </com.google.android.material.textfield.TextInputLayout>

        </LinearLayout>

    </LinearLayout>

</ScrollView>
