<?xml version="1.0" encoding="utf-8"?>
<ScrollView
	xmlns:android="http://schemas.android.com/apk/res/android"
	android:layout_width="match_parent"
	android:layout_height="wrap_content">

	<LinearLayout
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:orientation="vertical"
		android:padding="24dp">

		<com.google.android.material.textfield.TextInputLayout
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:hint="Clone label suffix">

			<com.google.android.material.textfield.TextInputEditText
				android:id="@+id/labelEditText"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:text="Clone"
				android:inputType="text"
				android:maxLines="1" />

		</com.google.android.material.textfield.TextInputLayout>

		<!-- Compatibility section header -->
		<LinearLayout
			android:id="@+id/compatibilityHeader"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:orientation="horizontal"
			android:layout_marginTop="20dp"
			android:paddingTop="8dp"
			android:paddingBottom="8dp"
			android:clickable="true"
			android:focusable="true"
			android:background="?android:attr/selectableItemBackground">

			<TextView
				android:layout_width="0dp"
				android:layout_height="wrap_content"
				android:layout_weight="1"
				android:text="Compatibility"
				android:textStyle="bold"
				android:textSize="14sp"
				android:textColor="?android:textColorPrimary" />

			<TextView
				android:id="@+id/compatibilityChevron"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:text="▸"
				android:textSize="14sp"
				android:textColor="?android:textColorSecondary" />

		</LinearLayout>

		<View
			android:layout_width="match_parent"
			android:layout_height="1dp"
			android:background="?android:attr/listDivider" />

		<!-- Compatibility content -->
		<LinearLayout
			android:id="@+id/compatibilityContent"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:orientation="vertical"
			android:visibility="gone">

			<com.google.android.material.checkbox.MaterialCheckBox
				android:id="@+id/deepCloneCheckbox"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:layout_marginTop="8dp"
				android:text="Deep clone (patch DEX strings)"
				android:checked="false" />

			<TextView
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:layout_marginTop="4dp"
				android:layout_marginStart="32dp"
				android:text="Fixes apps that hardcode their own package name in code. Slower but more compatible."
				android:textSize="12sp"
				android:textColor="?android:textColorSecondary" />

			<com.google.android.material.checkbox.MaterialCheckBox
				android:id="@+id/patchNativeCheckbox"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:layout_marginTop="12dp"
				android:text="Patch native libraries (risky)"
				android:checked="false" />

			<TextView
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:layout_marginTop="4dp"
				android:layout_marginBottom="8dp"
				android:layout_marginStart="32dp"
				android:text="Replaces package name in .so files. May corrupt binaries — only use if clone crashes without it."
				android:textSize="12sp"
				android:textColor="?android:textColorSecondary" />

		</LinearLayout>

		<!-- Manifest section header -->
		<LinearLayout
			android:id="@+id/manifestHeader"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:orientation="horizontal"
			android:layout_marginTop="12dp"
			android:paddingTop="8dp"
			android:paddingBottom="8dp"
			android:clickable="true"
			android:focusable="true"
			android:background="?android:attr/selectableItemBackground">

			<TextView
				android:layout_width="0dp"
				android:layout_height="wrap_content"
				android:layout_weight="1"
				android:text="Manifest"
				android:textStyle="bold"
				android:textSize="14sp"
				android:textColor="?android:textColorPrimary" />

			<TextView
				android:id="@+id/manifestChevron"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:text="▸"
				android:textSize="14sp"
				android:textColor="?android:textColorSecondary" />

		</LinearLayout>

		<View
			android:layout_width="match_parent"
			android:layout_height="1dp"
			android:background="?android:attr/listDivider" />

		<!-- Manifest content -->
		<LinearLayout
			android:id="@+id/manifestContent"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:orientation="vertical"
			android:visibility="gone">

			<com.google.android.material.textfield.TextInputLayout
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:layout_marginTop="12dp"
				android:hint="Min SDK version (leave empty to keep original)">

				<com.google.android.material.textfield.TextInputEditText
					android:id="@+id/minSdkEditText"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:inputType="number"
					android:maxLines="1" />

			</com.google.android.material.textfield.TextInputLayout>

			<com.google.android.material.textfield.TextInputLayout
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:layout_marginTop="12dp"
				android:layout_marginBottom="8dp"
				android:hint="Target SDK version (leave empty to keep original)">

				<com.google.android.material.textfield.TextInputEditText
					android:id="@+id/targetSdkEditText"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:inputType="number"
					android:maxLines="1" />

			</com.google.android.material.textfield.TextInputLayout>

		</LinearLayout>

	</LinearLayout>

</ScrollView>
